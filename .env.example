# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Combined sign-in-or-up (modal + SSO). Do NOT set SIGN_UP_URL — it breaks
# OAuth callbacks that must stay under /sign-in (e.g. /sign-in/create/sso-callback).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# MongoDB
MONGODB_URI=

# Demo seeding (Phase 20.1) — development only
# ALLOW_DEMO_SEED=true
# Required for `npm run seed:reset` against non-local / non-dev-named databases:
# ALLOW_DEMO_SEED_RESET=true

# Cloudinary (optional — for file uploads in a later phase)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
